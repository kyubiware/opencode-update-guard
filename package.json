{
  "name": "opencode-update-guard",
  "version": "0.3.4",
  "description": "OpenCode plugin that checks for dependency updates with a maturity cooldown",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node bin/install.cjs",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format",
    "format:fix": "biome format --write",
    "logs": "cat ${XDG_CACHE_HOME:-$HOME/.cache}/opencode/update-guard-debug.log 2>/dev/null || echo 'No debug log found. Enable \"debug\": true in ~/.config/opencode/update-guard.jsonc and restart opencode.'",
    "ci": "biome check --fix && tsc && vitest run",
    "cli": "tsx src/cli.ts",
    "release": "bun scripts/release.ts",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@opencode-ai/plugin": "^1.4.9",
    "@types/node": "22",
    "lint-staged": "^17.0.4",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  },
  "bin": {
    "opencode-update": "./dist/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "update-guard.schema.json"
  ],
  "license": "MIT",
  "author": "kyubiware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyubiware/opencode-update-guard.git"
  },
  "bugs": {
    "url": "https://github.com/kyubiware/opencode-update-guard/issues"
  },
  "homepage": "https://github.com/kyubiware/opencode-update-guard#readme",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "supply-chain",
    "security",
    "update",
    "npm",
    "maturity"
  ],
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  }
}

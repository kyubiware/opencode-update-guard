{
  "name": "opencode-update-guard",
  "version": "0.1.2",
  "description": "OpenCode plugin that checks for dependency updates with a maturity cooldown",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node bin/install.cjs",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format",
    "format:fix": "biome format --write",
    "prepare": "simple-git-hooks"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": "biome check --fix --no-errors-on-unmatched"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@opencode-ai/plugin": "^1.4.9",
    "@types/node": "22",
    "lint-staged": "^17.0.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "license": "MIT",
  "author": "kyubiware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyubiware/opencode-update-guard.git"
  },
  "bugs": {
    "url": "https://github.com/kyubiware/opencode-update-guard/issues"
  },
  "homepage": "https://github.com/kyubiware/opencode-update-guard#readme",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "supply-chain",
    "security",
    "update",
    "npm",
    "maturity"
  ]
}
